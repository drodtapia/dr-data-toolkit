# Python cache
__pycache__/
*.py[cod]
*$py.class

# Package/build artifacts
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Test/cache
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# Virtual environments
.venv/
venv/
env/
ENV/

# Jupyter
.ipynb_checkpoints/

# Project data - keep folders with .gitkeep only
data/raw/*
!data/raw/.gitkeep

data/processed/*
!data/processed/.gitkeep

output/*
!output/.gitkeep
!output/reports/
output/reports/*
!output/reports/.gitkeep

logs/*
!logs/.gitkeep

# Generated templates from examples
templates/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editors
.vscode/
.idea/

# Excel temporary files
~$*.xlsx
~$*.xlsm
~$*.xls

# Misc
*.log
